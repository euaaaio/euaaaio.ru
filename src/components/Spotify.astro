---
import iconSpotifyDark from '@/assets/icons/spotify-dark.svg'
import iconSpotifyLight from '@/assets/icons/spotify-light.svg'
---

<dl class="spotify">
  <dt>
    <picture>
      <source
        media="(prefers-color-scheme: light)"
        srcset={iconSpotifyLight.src}
      />
    </picture>
    <img alt="Spotify Logo" src={iconSpotifyDark.src} />
    <a
      class="spotify__link"
      href="https://spotify.com"
      rel="noopener"
      target="_blank"
    >
    </a>
  </dt>
  <dd>
    <slot />
  </dd>
</dl>

<script is:inline>
  const spotifyEl = document.querySelector('.spotify')
  const spotifiLinkEl = document.querySelector('.spotify__link')

  async function updateSpotify() {
    try {
      const res = await fetch('/api/spotify')
      if (res.status !== 200) {
        spotifyEl.style.display = 'none'
      }

      const player = await res.json()
      if (player.playing === false) {
        spotifyEl.style.display = 'none'
      } else {
        spotifyEl.style.display = 'block'
        spotifiLinkEl.href = player.url
        spotifiLinkEl.innerHTML = `${player.artist} <br>${player.song}`
      }
    } catch (error) {
      console.error(error)
      spotifyEl.style.display = 'none'
    }

    setTimeout(updateSpotify, 10_000)
  }

  updateSpotify()
</script>

<style>
  .spotify {
    display: none;
    text-transform: none;
  }

  .spotify :global(dt a) {
    display: block;
    margin-top: 10px;
  }

  .spotify :global(dd) {
    text-transform: none;
  }

  .spotify__icon {
    vertical-align: top;
  }

  .spotify__link {
    text-decoration: none;
  }
</style>
